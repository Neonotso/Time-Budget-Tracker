# Dedicated secret folders
.secrets/
**/.secrets/

# --- OpenClaw runtime / local state ---
.openclaw/
backups/

# --- Personal memory/docs ---
# Intentionally tracked unless they contain secrets.
# If a specific file later needs to stay local, ignore it explicitly.

# --- Dependency / build caches ---
node_modules/
**/node_modules/
.venv/
**/.venv/
venv/
**/venv/
__pycache__/
**/__pycache__/
.pytest_cache/
.mypy_cache/
.cache/
**/.cache/
.next/
**/.next/
dist/
**/dist/
build/
**/build/
coverage/

# --- Firebase local cache ---
.firebase/
**/.firebase/

# --- Optional: keep examples tracked ---
!.env.example
!**/.env.example

# --- Package locks / manifests should stay tracked ---
!package-lock.json
!package.json**/.DS_Store
