# --- OS / editor noise ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Git / logs ---
*.log
*.out
*.err
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Secrets / credentials ---
.env
.env.*
*.env
*.local
*.secret
*.secrets
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
*.csr
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
credentials.json
config.json
